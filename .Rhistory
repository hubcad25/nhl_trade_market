env <- lsf.str()
# only keep functions starting with "get_player" in it
fcts <- env[grepl("get_player", env)]
for (f in fcts) {
col <- gsub("get_player_", "", f)
df[[col]] <- sapply(list, function(x) do.call(f, list(x)))
print(col)
}
View(df)
