nhl_ids <- readRDS("data/sample_nhl_ids.rds")
hist(nhl_ids)
i <- nhl_ids[1]
list <- get_list_of_infos(i)
View(list)
nhl_id <- nhl_ids[i]
list <- get_list_of_infos(nhl_id)
i <- 1
nhl_id <- nhl_ids[i]
list <- get_list_of_infos(nhl_id)
list
listi <- get_list_of_infos(nhl_id)
if (i == 1){
list <- list()
list[1] <- listi
}
list[[1]] <- listi
listi <- get_list_of_infos(nhl_id)
if (i == 1){
list <- list()
list[[1]] <- listi
}
View(list)
for (i in 1:length(nhl_ids)){
#i <- 1
nhl_id <- nhl_ids[i]
listi <- get_list_of_infos(nhl_id)
if (i == 1){
list <- list()
list[[1]] <- listi
} else {
list[[2]] <- listi
}
}
