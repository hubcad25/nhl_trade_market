get_list_of_infos <- function(player_id){
player_id <- as.character(player_id)
url <- paste0("https://statsapi.web.nhl.com/api/v1/people/", player_id)
json <- api(url) %>% http()
return(json)
}
get_list_of_infos <- function(player_id){
player_id <- as.character(player_id)
url <- paste0("https://statsapi.web.nhl.com/api/v1/people/", player_id)
json <- api(url) %>% http()
return(json)
}
get_list_of_infos <- function(player_id){
player_id <- as.character(player_id)
url <- paste0("https://statsapi.web.nhl.com/api/v1/people/", player_id)
list <- api(url) %>% http()
return(list)
}
