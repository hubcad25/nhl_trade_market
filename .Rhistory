bnk <- read.csv("data/explo_neuralnet/bank-full.csv")
bnk <- read.csv("data/explo_neuralnet/bank-full.csv", sep = ",")
bnk <- read.csv("data/explo_neuralnet/bank-full.csv", sep = ";")
View(bnk)
bnk$balance <- clessnverse::normalize_min_max(bnk$balance)
bnk$age <- clessnverse::normalize_min_max(bnk$age)
bnk$campaign <- clessnverse::normalize_min_max(bnk$campaign)
bnk <- read.csv("data/explo_neuralnet/bank-full.csv", sep = ";")
bnk$balance <- clessnverse::normalize_min_max(bnk$balance)
bnk$age <- clessnverse::normalize_min_max(bnk$age)
bnk$previous <- clessnverse::normalize_min_max(bnk$previous)
bnk$campaign <- clessnverse::normalize_min_max(bnk$campaign)
bnk$education <- relevel(bnk$education, ref = "secondary")
bnk$education <- relevel(factor(bnk$education), ref = "secondary")
head(model.matrix(~education, data=bnk))
bnk_matrix <- model.matrix(~age+job+marital+education
+default+balance+housing
+loan+poutcome+campaign
+previous+y, data=bnk)
View(bnk_matrix)
names(bnk_matrix)
colnames(bnk_matrix)
bnk <- read.csv("data/explo_neuralnet/bank.csv", sep = ";")
bnk <- read.csv("data/explo_neuralnet/bank-full.csv", sep = ";")
bnk$balance <- clessnverse::normalize_min_max(bnk$balance)
bnk$age <- clessnverse::normalize_min_max(bnk$age)
bnk$previous <- clessnverse::normalize_min_max(bnk$previous)
bnk$campaign <- clessnverse::normalize_min_max(bnk$campaign)
bnk$education <- relevel(factor(bnk$education), ref = "secondary")
head(model.matrix(~education, data=bnk))
bnk_matrix <- model.matrix(~age+job+marital+education
+default+balance+housing
+loan+poutcome+campaign
+previous+y, data=bnk)
colnames(bnk_matrix)
colnames(bnk_matrix) <- gsub("-", "", colnames(bnk_matrix))
col_list <- paste(c(colnames(bnk_matrix[,-c(1,28)])),collapse="+")
col_list <- paste(c("yyes~",col_list),collapse="")
f <- formula(col_list)
f
summary(lm(formula = formula, data = bnk_matrix))
set.seed(46553)
nmodel <- neuralnet(f,data=bnk_matrix,hidden=c(3,3),
threshold = 0.01,
learningrate.limit = NULL,
learningrate.factor =
list(minus = 0.5, plus = 1.2),
algorithm = "rprop+")
plot.nn(nmodel)
neuralnet::gwplot(nmodel)
bnk_matrix[,1]
bnk_matrix[1,]
nrow(bnk_matrix)
nmodel <- neuralnet(f,data=bnk_matrix[sample(1:nrow(bnk_matrix), 10000),],hidden=c(2,2),
threshold = 0.01,
learningrate.limit = NULL,
learningrate.factor =
list(minus = 0.5, plus = 1.2),
algorithm = "rprop+")
nmodel <- neuralnet(f,data=bnk_matrix[sample(1:nrow(bnk_matrix), 100),],hidden=c(2,2),
threshold = 0.01,
learningrate.limit = NULL,
learningrate.factor =
list(minus = 0.5, plus = 1.2),
algorithm = "rprop+")
neuralnet::gwplot(nmodel)
plot(nmodel)
nmodel <- neuralnet(f,data=bnk_matrix[sample(1:nrow(bnk_matrix), 1000),],hidden=c(2,2),
threshold = 0.01,
learningrate.limit = NULL,
learningrate.factor =
list(minus = 0.5, plus = 1.2),
algorithm = "rprop+")
neuralnet::gwplot(nmodel)
plot(nmodel)
load(url("https://cbail.github.io/Elected_Official_Tweets.Rdata"))
View(elected_official_tweets)
library(tidytext)
library(dplyr)
# We want to use original tweets, not retweets:
elected_no_retweets <- elected_official_tweets %>%
filter(is_retweet == F) %>%
select(c("text"))
#create tweet id
elected_no_retweets$postID<-row.names(elected_no_retweets)
library(widyr)
install.packages("widyr")
library(widyr)
#create context window with length 8
tidy_skipgrams <- elected_no_retweets %>%
unnest_tokens(ngram, text, token = "ngrams", n = 8) %>%
mutate(ngramID = row_number()) %>%
tidyr::unite(skipgramID, postID, ngramID) %>%
unnest_tokens(word, ngram)
View(tidy_skipgrams)
